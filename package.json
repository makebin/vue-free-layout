{
  "name": "vue-free-layout",
  "version": "1.0.0",
  "description": "高性能 Vue3 自由布局组件，支持像素/百分比混合定位、流畅动画、ResizeObserver 自适应",
  "author": "mk9007@163.com",
  "license": "MIT",
  "homepage": "https://github.com/makebin/vue-free-layout",
  "repository": {
    "type": "git",
    "url": "https://github.com/makebin/vue-free-layout"
  },
  "keywords": [
    "vue",
    "vue3",
    "layout",
    "free-layout",
    "absolute-positioning",
    "dashboard",
    "resizable",
    "component"
  ],
  "type": "module",
  "main": "./dist/vue-free-layout.umd.cjs",
  "module": "./dist/vue-free-layout.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-free-layout.js",
      "require": "./dist/vue-free-layout.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:demo": "cd demo && vite",
    "build": "vite build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
